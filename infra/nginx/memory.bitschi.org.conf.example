# Memory Distiller Nginx Configuration
# Domain: memory.bitschi.org
#
# Install:
#   cp memory.bitschi.org.conf.example /etc/nginx/sites-available/memory.bitschi.org
#   ln -s /etc/nginx/sites-available/memory.bitschi.org /etc/nginx/sites-enabled/
#   nginx -t && systemctl reload nginx
#
# Certbot HTTPS:
#   certbot --nginx -d memory.bitschi.org
#   # Certbot will add SSL directives and redirect HTTP->HTTPS automatically.

server {
    listen 80;
    listen [::]:80;

    server_name memory.bitschi.org;

    # Basic Authentication
    auth_basic "Memory Distiller";
    auth_basic_user_file /etc/nginx/.htpasswd-memory-distiller;

    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 86400;
    }
}
